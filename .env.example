# Copy this file to .env.local and fill in the values, then restart `npm run dev`.
# .env.local is git-ignored. Only VITE_-prefixed vars reach the browser — never
# put a service_role key or a Stripe SECRET key here.
# See BACKEND_SETUP.md §2 for where to find each value.

# --- Supabase (Project Settings → API) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Stripe (only needed once you wire payments — Step G). Publishable = safe. ---
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
